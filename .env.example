# Local dev:
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/zimson_service_management
# Production (AWS RDS): see env.production.example and docs/DEPLOYMENT-zimsonwatchcare.md

# --- GST company name lookup (/api/gst/lookup) ---
# Option A — Masters India (recommended for Zimson): OAuth password grant + search GSTIN
# MASTERS_INDIA_USERNAME=
# MASTERS_INDIA_PASSWORD=
# MASTERS_INDIA_CLIENT_ID=
# MASTERS_INDIA_CLIENT_SECRET=
# Optional overrides (defaults: commonapi.mastersindia.co):
# MASTERS_INDIA_TOKEN_URL=https://commonapi.mastersindia.co/oauth/access_token
# MASTERS_INDIA_API_BASE_URL=https://commonapi.mastersindia.co

# Option B — Sandbox.co.in: API key + secret from https://console.sandbox.co.in/
# GST_LOOKUP_SANDBOX_API_KEY=
# GST_LOOKUP_SANDBOX_API_SECRET=
# Optional: use Sandbox test host (default is production https://api.sandbox.co.in)
# GST_LOOKUP_SANDBOX_TEST=true
# Optional override for base URL:
# GST_LOOKUP_SANDBOX_BASE_URL=https://api.sandbox.co.in

# --- E-invoice & e-way (Masters India sandbox / production) ---
# Same portal login as e-doc (not commonapi GST lookup OAuth).
# MASTERS_INDIA_EDOC_USERNAME=
# MASTERS_INDIA_EDOC_PASSWORD=
# MASTERS_INDIA_EDOC_ENABLED=true
# MASTERS_INDIA_EDOC_FAIL_OPEN=true
# MASTERS_INDIA_EDOC_API_BASE=https://sandb-api.mastersindia.co
# MASTERS_INDIA_EDOC_EWAY_API_BASE=https://sandb-api.edoc.mastersindia.co
# MASTERS_INDIA_EDOC_TOKEN_URL=https://sandb-api.mastersindia.co/api/v1/token-auth/
# Sandbox registered GSTINs (override store GSTIN when testing):
# MASTERS_INDIA_EDOC_SELLER_GSTIN=09AAAPG7885R002
# MASTERS_INDIA_EDOC_EWAY_GSTIN=05AAABC0181E1ZE
# MASTERS_INDIA_EDOC_EWAY_NOMINAL_INR=1000
# MASTERS_INDIA_EDOC_EWAY_AUTO=false

# Option C — Your own HTTP gateway: GET URL must include {gstin}; key sent as Authorization: Bearer <key>
# Example: GST_LOOKUP_HTTP_URL=https://your-api.example.com/v1/gst/{gstin}
# GST_LOOKUP_API_KEY=

# Option D — Explorium (https://admin.explorium.ai/api-key is only where you COPY the key in the browser).
# Server calls https://api.explorium.ai with header api_key (see https://developers.explorium.ai/reference/setup/getting_your_api_key.md).
# Note: Explorium matches companies by name/domain, not India GST registry; use Sandbox (Option A) for official GSTIN legal/trade names.
# GST_LOOKUP_EXPLORIUM_API_KEY=
# Optional: GST_LOOKUP_EXPLORIUM_BASE_URL=https://api.explorium.ai

# --- Amazon S3 (production: zimson-dev-files, ap-south-2) ---
# FILES_STORAGE=s3
# AWS_REGION=ap-south-2
# AWS_S3_BUCKET=zimson-dev-files
# AWS_S3_PREFIX=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_MEDIA_REDIRECT=true
# S3_PRESIGN_SECONDS=3600

# Public URL of the web app (where /track and photo links open). Customers receive links built from this.
# Local: http://localhost:5173  |  LAN server: http://192.168.x.x:5173  |  Production: https://your-domain.com
# If unset, the API uses the browser Origin header (correct for Vite dev) or maps API port to WEB_DEV_PORT.
# APP_BASE_URL=http://localhost:5173

# When the API runs on PORT (default 4000) and Host is that port, tracking links use this as the UI port (Vite default 5173).
# WEB_DEV_PORT=5173

# --- E-invoice & e-way (Masters India) — configure in Settings → E-invoice & e-way (super admin) ---
# On first boot, MASTERS_INDIA_EDOC_* / MASTERS_INDIA_USERNAME vars are imported into PostgreSQL once.
# MASTERS_INDIA_EDOC_USERNAME=
# MASTERS_INDIA_EDOC_PASSWORD=
# MASTERS_INDIA_EDOC_ENABLED=true
# MASTERS_INDIA_EDOC_FAIL_OPEN=true
# MASTERS_INDIA_EDOC_API_BASE=https://sandb-api.mastersindia.co
# MASTERS_INDIA_EDOC_EWAY_API_BASE=https://sandb-api.edoc.mastersindia.co
# MASTERS_INDIA_EDOC_TOKEN_URL=https://sandb-api.mastersindia.co/api/v1/token-auth/
# MASTERS_INDIA_EDOC_SELLER_GSTIN=09AAAPG7885R002
# MASTERS_INDIA_EDOC_EWAY_GSTIN=05AAABC0181E1ZE

# --- Messaging (SMS, email, WhatsApp) ---
# Configure in the app: Settings → SMS, email & WhatsApp (super admin). Values are stored in PostgreSQL.
# On first boot, existing QIKBERRY_*/SMTP_*/QIKCHAT_* vars below are imported into the DB once.

# QIKBERRY_SMS_TOKEN=your-access-token-only-no-bearer-prefix
# QIKBERRY_SMS_TEMPLATE_ID=1707175871295951368
# QIKBERRY_SMS_SENDER=ZIMSON
# QIKBERRY_SMS_SERVICE=SI
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@zimsonwatchcare.com
# SMTP_PASSWORD=your-google-app-password
# SMTP_FROM=Zimson Watch Care <noreply@zimsonwatchcare.com>
# SMTP_REPLY_TO=support@zimsonwatchcare.com
# Inbox delivery: SPF + DKIM + DMARC on the From domain — see docs/EMAIL_DELIVERABILITY.md
# Public app URL for password-reset links (must match your live site — avoids spam flags from localhost/ngrok)
# APP_BASE_URL=https://app.zimsonwatchcare.com
# QIKCHAT_API_KEY=your-qikchat-key
# QIKCHAT_WHATSAPP_TEMPLATE_NAME=invoice
# QIKCHAT_TRACKING_TEMPLATE_NAME=customer_link
# Body-only fallback when SRF PDF cannot be published (optional; same body vars, no document header)
# QIKCHAT_TRACKING_TEXT_TEMPLATE_NAME=customer_link_text
# QIKCHAT_APPROVAL_TEMPLATE_NAME=site_visit_approval
# Public HTTPS host where /api reaches Node (WhatsApp PDF: https://host/api/messaging/public-invoice-pdf/…)
# Production server: must be https (http is upgraded automatically). Not localhost.
MESSAGING_PUBLIC_BASE_URL=https://zimsonwatchcare.com
# Until SMTP works: show OTP / password-reset links on screen instead of email (auto when SMTP empty)
# MESSAGING_EXPOSE_DEMO_OTP=true
# PASSWORD_RESET_DEMO_UI=true

# Dev-only infrastructure (stay in .env):
# MESSAGING_AUTO_TUNNEL=true
# MESSAGING_TUNNEL_PROVIDER=cloudflared
# CLOUDFLARED_PATH=C:\Program Files (x86)\cloudflared\cloudflared.exe
