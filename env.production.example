# =============================================================================
# Zimson Service Management — production (EC2 18.61.69.104, zimsonwatchcare.com)
# Copy to .env on the server:  cp env.production.example .env
# Then fill AWS S3 keys and run: npm run certs:rds && npm run db:migrate
# =============================================================================

NODE_ENV=production
PORT=4000
# Bind locally only — Nginx (port 80/443) is public; do not open 4000 in AWS security group
HOST=127.0.0.1

# --- PostgreSQL (AWS RDS ap-south-2) ---
# Create DB once:  CREATE DATABASE zimson;
# Password special chars must be URL-encoded (# → %23)
DATABASE_URL=postgresql://zimson:ZimsonDev2026%23DB@zimson-dev-db.cta2eesy8zfj.ap-south-2.rds.amazonaws.com:5432/zimson
PGSSLMODE=verify-full
PGSSLROOTCERT=./certs/global-bundle.pem

# --- Public URLs (no :4000 — Nginx on port 80/443) ---
APP_BASE_URL=https://zimsonwatchcare.com
MESSAGING_PUBLIC_BASE_URL=https://zimsonwatchcare.com
# Required for password-reset / tracking links in email (localhost does not work in Gmail)

# --- File storage (SRF photos, Quick Bill documents/images) ---
FILES_STORAGE=s3
AWS_REGION=ap-south-2
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME
AWS_S3_PREFIX=zimson
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Presigned redirect for private bucket (recommended)
S3_MEDIA_REDIRECT=true
S3_PRESIGN_SECONDS=3600

# --- OTP / email (Google Workspace) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@zimsonwatchcare.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Zimson Watch Care <noreply@zimsonwatchcare.com>
MESSAGING_EXPOSE_DEMO_OTP=false

# --- Qikberry SMS ---
QIKBERRY_SMS_URL=https://rest.qikberry.ai/v1/sms/messages
QIKBERRY_SMS_TOKEN=
QIKBERRY_SMS_TEMPLATE_ID=1707175871295951368
QIKBERRY_SMS_SENDER=ZIMSON
QIKBERRY_SMS_SERVICE=SI

# --- WhatsApp (Qikchat) ---
QIKCHAT_API_KEY=
QIKCHAT_WHATSAPP_TEMPLATE_NAME=invoice
WHATSAPP_INVOICE_MODE=template
WHATSAPP_INVOICE_DRY_RUN=false
MESSAGING_AUTO_TUNNEL=false

# --- GST lookup (Sandbox) ---
GST_LOOKUP_SANDBOX_API_KEY=
GST_LOOKUP_SANDBOX_API_SECRET=
