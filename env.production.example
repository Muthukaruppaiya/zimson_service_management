# =============================================================================
# Zimson Service Management — production (EC2, zimsonwatchcare.com)
# Copy on server:  cp env.production.example .env   then fill secrets and restart API
# Nginx: proxy /api and /uploads to http://127.0.0.1:4000 (see deploy/nginx-zimsonwatchcare-ssl.conf)
# =============================================================================

NODE_ENV=production
HOST=127.0.0.1
PORT=4000

# --- Public URLs (HTTPS — SSL on Nginx 443) ---
APP_BASE_URL=https://zimsonwatchcare.com
# WhatsApp invoice PDFs: https://zimsonwatchcare.com/api/messaging/public-invoice-pdf/inv-….pdf
MESSAGING_PUBLIC_BASE_URL=https://zimsonwatchcare.com

# --- PostgreSQL (AWS RDS ap-south-2) ---
# Password special chars must be URL-encoded (# → %23)
DATABASE_URL=postgresql://zimson:YOUR_PASSWORD@zimson-dev-db.cta2eesy8zfj.ap-south-2.rds.amazonaws.com:5432/zimson
PGSSLMODE=verify-full
PGSSLROOTCERT=./certs/global-bundle.pem

# --- File storage ---
# Recommended for production WhatsApp invoices (direct HTTPS PDF to Qikchat):
FILES_STORAGE=s3
AWS_REGION=ap-south-2
AWS_S3_BUCKET=YOUR_S3_BUCKET_NAME
AWS_S3_PREFIX=zimson
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_MEDIA_REDIRECT=true
S3_PRESIGN_SECONDS=3600

# If you must use disk only (no S3), uncomment and comment S3 block above:
# FILES_STORAGE=local

# --- Dev tunnel (OFF on server) ---
MESSAGING_AUTO_TUNNEL=false

# --- GSTIN company lookup (/api/gst/lookup) — pick ONE provider ---
# Option A — Masters India (preferred when all four are set; checked before Sandbox):
MASTERS_INDIA_USERNAME=
MASTERS_INDIA_PASSWORD=
MASTERS_INDIA_CLIENT_ID=
MASTERS_INDIA_CLIENT_SECRET=
# MASTERS_INDIA_TOKEN_URL=https://commonapi.mastersindia.co/oauth/access_token
# MASTERS_INDIA_API_BASE_URL=https://commonapi.mastersindia.co

# Option B — Sandbox.co.in (fallback if Masters India not fully configured):
GST_LOOKUP_SANDBOX_API_KEY=
GST_LOOKUP_SANDBOX_API_SECRET=
# GST_LOOKUP_SANDBOX_TEST=false
# GST_LOOKUP_SANDBOX_BASE_URL=https://api.sandbox.co.in

# --- Qikberry SMS ---
QIKBERRY_SMS_URL=https://rest.qikberry.ai/v1/sms/messages
QIKBERRY_SMS_TOKEN=
QIKBERRY_SMS_TEMPLATE_ID=1707175871295951368
QIKBERRY_SMS_SENDER=ZIMSON
QIKBERRY_SMS_SERVICE=SI
QIKBERRY_SMS_OTP_MESSAGE=Dear Customer, Your One Time Password is {{1}}. Please use this code to complete your verification - ZIMSON

# --- Email (Google Workspace SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@zimsonwatchcare.com
SMTP_PASSWORD=
SMTP_FROM=Zimson Watch Care <noreply@zimsonwatchcare.com>
SMTP_REPLY_TO=support@zimsonwatchcare.com
MESSAGING_EXPOSE_DEMO_OTP=false

# --- WhatsApp invoices (Qikchat) ---
QIKCHAT_API_KEY=
QIKCHAT_WHATSAPP_TEMPLATE_NAME=invoice
QIKCHAT_WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_INVOICE_MODE=template
WHATSAPP_INVOICE_DRY_RUN=false
QIKBERRY_WORKDRIVE_FOR_INVOICE=false

# Optional Work Drive (separate token from SMS — only if QIKBERRY_WORKDRIVE_FOR_INVOICE=true):
# QIKBERRY_WORKDRIVE_TOKEN=
# QIKBERRY_WORKDRIVE_UPLOAD_URL=https://wkdrive.qikberry.io/api/v1/upload
