# =============================================================================
# Zimson Service Management — production (EC2, zimsonwatchcare.com)
# Copy on server:  cp env.production.example .env   then fill secrets and restart API
# EC2 public IP: 40.192.16.186 — DNS A records for zimsonwatchcare.com / www → this IP
# Nginx: proxy /api and /uploads to http://127.0.0.1:4000 (see deploy/nginx-zimsonwatchcare-ssl.conf)
# =============================================================================

NODE_ENV=production
HOST=127.0.0.1
PORT=4000

# --- Public URLs (HTTPS — SSL on Nginx 443) ---
APP_BASE_URL=https://zimsonwatchcare.com

# --- PostgreSQL (AWS RDS ap-south-2) ---
# Password special chars must be URL-encoded (# → %23)
DATABASE_URL=postgresql://zimson:YOUR_PASSWORD@zimson-dev-db.cta2eesy8zfj.ap-south-2.rds.amazonaws.com:5432/zimson
PGSSLMODE=verify-full
PGSSLROOTCERT=./certs/global-bundle.pem

# --- File storage (Amazon S3 — bucket zimson-dev-files, ap-south-2) ---
# Folders at bucket root: srf/, quick-bill/, customer-documents/, service-photos/, reports/, Invoices/, temp/
FILES_STORAGE=s3
AWS_REGION=ap-south-2
AWS_S3_BUCKET=zimson-dev-files
AWS_S3_PREFIX=
# EC2 IAM role: leave keys empty. Local/dev with keys only if not using instance role:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_MEDIA_REDIRECT=true
S3_PRESIGN_SECONDS=3600

# Local disk only (dev fallback):
# FILES_STORAGE=local

# --- Dev tunnel (OFF on server) ---
MESSAGING_AUTO_TUNNEL=false

# --- GSTIN company lookup (/api/gst/lookup) — pick ONE provider ---
# Option A — Masters India (preferred when all four are set; checked before Sandbox):
MASTERS_INDIA_USERNAME=
MASTERS_INDIA_PASSWORD=
MASTERS_INDIA_CLIENT_ID=
MASTERS_INDIA_CLIENT_SECRET=
# MASTERS_INDIA_TOKEN_URL=https://commonapi.mastersindia.co/oauth/access_token
# MASTERS_INDIA_API_BASE_URL=https://commonapi.mastersindia.co

# Option B — Sandbox.co.in (fallback if Masters India not fully configured):
GST_LOOKUP_SANDBOX_API_KEY=
GST_LOOKUP_SANDBOX_API_SECRET=
# GST_LOOKUP_SANDBOX_TEST=false
# GST_LOOKUP_SANDBOX_BASE_URL=https://api.sandbox.co.in

# --- SMS, email, WhatsApp, e-invoice / e-way ---
# Configure in the app (super admin): Settings → SMS, email & WhatsApp · Settings → E-invoice & e-way
# Public PDF base URL for WhatsApp: same field in messaging settings (e.g. https://zimsonwatchcare.com)
