# Use Express API + JSON persistence (proxied as /api). Set to false for legacy localStorage-only UI.
VITE_USE_API=true

# WhatsApp invoice PDFs — auto HTTPS tunnel to port 4000 (requires cloudflared on PATH or CLOUDFLARED_PATH)
MESSAGING_AUTO_TUNNEL=true
MESSAGING_TUNNEL_PROVIDER=cloudflared
CLOUDFLARED_PATH=C:\Program Files (x86)\cloudflared\cloudflared.exe

# Optional: skip WhatsApp and only save PDF locally while testing
# WHATSAPP_INVOICE_DRY_RUN=true
