{
  "name": "wireframe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production tsx --tsconfig server/tsconfig.json server/index.ts",
    "typecheck:server": "tsc --noEmit --project server/tsconfig.json",
    "certs:rds": "node scripts/fetch-rds-ca.mjs",
    "env:sync-smtp": "node scripts/update-smtp-settings.mjs"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "exceljs": "^4.4.0",
    "localtunnel": "^2.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@aws-sdk/s3-request-presigner": "^3.1056.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "html2pdf.js": "^0.10.2",
    "jsbarcode": "^3.12.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  }
}
